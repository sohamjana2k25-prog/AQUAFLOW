# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# Get these from your Supabase project settings
# https://app.supabase.com

SUPABASE_URL=
SUPABASE_KEY=

# ============================================================
# OPENWEATHERMAP API
# ============================================================
# Get your free API key from https://openweathermap.org/api
# One Call API 3.0 (free tier includes this)

OPENWEATHERMAP_API_KEY=

# ============================================================
# APPLICATION SETTINGS
# ============================================================
# Port for the FastAPI server (default: 8000)
PORT=8000

# Environment: development or production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================
# CITY CONFIGURATION (Optional - Customize for your city)
# ============================================================
# These are configured in the CITY_SECTORS dictionary in main.py
# Add/modify sectors based on your city's geography

CITY_NAME=Kolkata
TIMEZONE=Asia/Kolkata
